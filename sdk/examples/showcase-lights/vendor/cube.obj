# Hand-authored face-split cube — each of 6 faces has its own 4
# vertices so per-vertex normals after `--compute-normals` come
# out equal to the face normal (flat-shaded cube faces, no
# rounded corners).
#
# Unit cube centered at origin, edge length 1.
#
# Authored for PSoXide `showcase-lights`; public domain.

# -Z face (verts 1-4)
v -0.5 -0.5 -0.5
v  0.5 -0.5 -0.5
v  0.5  0.5 -0.5
v -0.5  0.5 -0.5

# +Z face (verts 5-8)
v -0.5 -0.5  0.5
v  0.5 -0.5  0.5
v  0.5  0.5  0.5
v -0.5  0.5  0.5

# -X face (verts 9-12)
v -0.5 -0.5 -0.5
v -0.5  0.5 -0.5
v -0.5  0.5  0.5
v -0.5 -0.5  0.5

# +X face (verts 13-16)
v  0.5 -0.5 -0.5
v  0.5 -0.5  0.5
v  0.5  0.5  0.5
v  0.5  0.5 -0.5

# -Y face (verts 17-20)
v -0.5 -0.5 -0.5
v -0.5 -0.5  0.5
v  0.5 -0.5  0.5
v  0.5 -0.5 -0.5

# +Y face (verts 21-24)
v -0.5  0.5 -0.5
v  0.5  0.5 -0.5
v  0.5  0.5  0.5
v -0.5  0.5  0.5

# Triangles — CCW when viewed from outside the cube.
# -Z face
f 1 2 3
f 1 3 4
# +Z face
f 5 7 6
f 5 8 7
# -X face
f 9 10 11
f 9 11 12
# +X face
f 13 14 15
f 13 15 16
# -Y face
f 17 18 19
f 17 19 20
# +Y face
f 21 23 22
f 21 24 23
